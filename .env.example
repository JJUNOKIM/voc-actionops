# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=voc_actionops
MYSQL_USER=local_user
MYSQL_PASSWORD=local_password
MYSQL_ROOT_PASSWORD=root_password

# Authentication
JWT_SECRET=replace-with-at-least-32-byte-secret
JWT_ACCESS_TOKEN_EXPIRATION=30m
JWT_REFRESH_TOKEN_EXPIRATION=14d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-bucket-name
AWS_SQS_ANALYSIS_QUEUE_URL=your-sqs-url

# AI
AI_PROVIDER=deterministic
AI_WORKER_API_KEY=replace-with-at-least-16-character-key
AI_WORKER_PORT=8000
OPENAI_MODEL=gpt-5.6-luna
OPENAI_API_KEY=your-api-key
OPENAI_TIMEOUT_SECONDS=30
AI_WORKER_BASE_URL=http://localhost:8000
